<Window x:Class="Compass.UI.BuildDrillWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Build a Drill"
        Width="780"
        Height="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        Background="#FFF5F6FA">
    <Border Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Margin="0,0,0,16">
                <TextBlock Text="Build a Drill"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#FF222B45" />
                <TextBlock Text="Choose a drill, shared zone, point count, and then resolve each path point from NAD83, NAD27, or section offsets."
                           Margin="0,4,0,0"
                           Foreground="#FF6B7280"
                           TextWrapping="Wrap" />
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="White"
                        BorderBrush="#FFE3E8EF"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Drill name"
                                       VerticalAlignment="Center"
                                       Foreground="#FF374151" />
                            <ComboBox Grid.Column="1"
                                      Margin="0,0,12,0"
                                      ItemsSource="{Binding DrillNames}"
                                      SelectedItem="{Binding SelectedDrillName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Column="2"
                                       Text="Zone"
                                       VerticalAlignment="Center"
                                       Foreground="#FF374151" />
                            <ComboBox Grid.Column="3"
                                      Margin="0,0,12,0"
                                      ItemsSource="{Binding ZoneChoices}"
                                      SelectedItem="{Binding SelectedZone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Column="4"
                                       Text="Point count"
                                       VerticalAlignment="Center"
                                       Foreground="#FF374151" />
                            <ComboBox Grid.Column="5"
                                      ItemsSource="{Binding PointCountChoices}"
                                      SelectedItem="{Binding PointCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="82" />
                                <ColumnDefinition Width="126" />
                                <ColumnDefinition Width="82" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="72" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="CORDS tag"
                                       VerticalAlignment="Center"
                                       Foreground="#FF374151" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Foreground="#FF111827"
                                       FontWeight="SemiBold"
                                       Text="{Binding PointTagPreview}" />

                            <TextBlock Grid.Column="2"
                                       Text="Surface"
                                       VerticalAlignment="Center"
                                       Foreground="#FF374151" />
                            <TextBlock Grid.Column="3"
                                       VerticalAlignment="Center"
                                       Foreground="#FF6B7280"
                                       Text="{Binding SurfacePointSummary}" />

                            <Button Grid.Column="4"
                                    Margin="8,0,8,0"
                                    Content="Get Surface"
                                    Click="GetSurface_Click" />
                            <Button Grid.Column="5"
                                    Content="Clear"
                                    IsEnabled="{Binding HasSurfacePoint}"
                                    Click="ClearSurface_Click" />
                        </Grid>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Points}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                        BorderBrush="#FFE3E8EF"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="{Binding PointLabel}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FF111827" />

                                         <Grid Margin="0,12,0,0">
                                             <Grid.ColumnDefinitions>
                                                 <ColumnDefinition Width="120" />
                                                 <ColumnDefinition Width="150" />
                                                 <ColumnDefinition Width="12" />
                                                 <ColumnDefinition Width="*" />
                                             </Grid.ColumnDefinitions>

                                             <TextBlock Grid.Column="0"
                                                        Text="Build from"
                                                        VerticalAlignment="Center"
                                                        Foreground="#FF374151" />
                                             <ComboBox Grid.Column="1"
                                                       Margin="0,0,0,0"
                                                       ItemsSource="{Binding SourceOptions}"
                                                       SelectedItem="{Binding SelectedSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       DisplayMemberPath="Label" />
                                         </Grid>

                                         <Grid Margin="0,10,0,0">
                                             <Grid.ColumnDefinitions>
                                                 <ColumnDefinition Width="160" />
                                                 <ColumnDefinition Width="120" />
                                                 <ColumnDefinition Width="12" />
                                                 <ColumnDefinition Width="*" />
                                             </Grid.ColumnDefinitions>

                                             <TextBlock Grid.Column="0"
                                                        Text="Combined scale factor"
                                                        VerticalAlignment="Center"
                                                        Foreground="#FF374151" />
                                             <TextBox Grid.Column="1"
                                                      Text="{Binding CombinedScaleFactor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                             <TextBlock Grid.Column="3"
                                                        VerticalAlignment="Center"
                                                        Foreground="#FF6B7280"
                                                        Text="Shared across all points. Section offsets use offset * CSF."
                                                        TextWrapping="Wrap" />
                                         </Grid>

                                         <Grid Margin="0,12,0,0"
                                               Visibility="{Binding CoordinateInputsVisibility}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding XLabel}"
                                                       VerticalAlignment="Center"
                                                       Foreground="#FF374151" />
                                            <TextBox Grid.Column="1"
                                                     Margin="0,0,12,0"
                                                     Text="{Binding XValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding YLabel}"
                                                       VerticalAlignment="Center"
                                                       Foreground="#FF374151" />
                                            <TextBox Grid.Column="3"
                                                     Text="{Binding YValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>

                                        <StackPanel Margin="0,12,0,0"
                                                    Visibility="{Binding SectionInputsVisibility}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="Section"
                                                           VerticalAlignment="Center"
                                                           Foreground="#FF374151" />
                                                <TextBox Grid.Column="1"
                                                         Margin="0,0,12,0"
                                                         Text="{Binding Section, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Grid.Column="2"
                                                           Text="Township"
                                                           VerticalAlignment="Center"
                                                           Foreground="#FF374151" />
                                                <TextBox Grid.Column="3"
                                                         Text="{Binding Township, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>

                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="Range"
                                                           VerticalAlignment="Center"
                                                           Foreground="#FF374151" />
                                                <TextBox Grid.Column="1"
                                                         Margin="0,0,12,0"
                                                         Text="{Binding Range, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Grid.Column="2"
                                                           Text="Meridian"
                                                           VerticalAlignment="Center"
                                                           Foreground="#FF374151" />
                                                <TextBox Grid.Column="3"
                                                         Text="{Binding Meridian, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>

                                            <CheckBox Margin="0,10,0,0"
                                                      Content="Use ATS hard boundaries"
                                                      IsChecked="{Binding UseAtsFabric, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="North / South offset"
                                                               Margin="0,0,0,6"
                                                               Foreground="#FF374151" />
                                                    <ComboBox ItemsSource="{Binding NorthSouthReferences}"
                                                              SelectedItem="{Binding SelectedNorthSouthReference, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              DisplayMemberPath="Label" />
                                                    <TextBox Margin="0,8,0,0"
                                                             Text="{Binding NorthSouthDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="East / West offset"
                                                               Margin="0,0,0,6"
                                                               Foreground="#FF374151" />
                                                    <ComboBox ItemsSource="{Binding EastWestReferences}"
                                                              SelectedItem="{Binding SelectedEastWestReference, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              DisplayMemberPath="Label" />
                                                    <TextBox Margin="0,8,0,0"
                                                             Text="{Binding EastWestDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Content="Cancel"
                        Width="96"
                        Padding="12,5"
                        Margin="0,0,8,0"
                        Click="Cancel_Click" />
                <Button Content="Build"
                        Width="96"
                        Padding="12,5"
                        IsDefault="True"
                        Click="Build_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
