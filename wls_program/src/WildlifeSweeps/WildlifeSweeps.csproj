<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <OutputType>Library</OutputType>
    <RootNamespace>WildlifeSweeps</RootNamespace>
    <AssemblyName>WildlifeSweeps</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <LangVersion>latest</LangVersion>
    <Nullable>annotations</Nullable>
    <NoWarn>CS8632;MSB3277</NoWarn>
    <ACAD_DIR Condition="'$(ACAD_DIR)' == ''">C:\Program Files\Autodesk\AutoCAD 2025</ACAD_DIR>
    <WildlifeLookupSourceFile>$(MSBuildProjectDirectory)\..\..\wildlife_parsing_codex_lookup.xlsx</WildlifeLookupSourceFile>
    <WildlifeLookupMirrorSourceFile>$(MSBuildProjectDirectory)\..\..\wildlife_parsing_codex_lookup_backup.xlsx</WildlifeLookupMirrorSourceFile>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="..\..\..\src\AtsBackgroundBuilder\Sections\SectionIndexReader.cs" Link="Shared\Ats\SectionIndexReader.cs" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="accoremgd">
      <HintPath>$(ACAD_DIR)\accoremgd.dll</HintPath>
    </Reference>
    <Reference Include="Acdbmgd">
      <HintPath>$(ACAD_DIR)\acdbmgd.dll</HintPath>
    </Reference>
    <Reference Include="Acmgd">
      <HintPath>$(ACAD_DIR)\acmgd.dll</HintPath>
    </Reference>
  </ItemGroup>

  <Target Name="CopyWildlifeLookup" AfterTargets="Build">
    <ItemGroup>
      <WildlifeLookupFiles Include="$(WildlifeLookupSourceFile)" Condition="Exists('$(WildlifeLookupSourceFile)')" />
      <WildlifeLookupFiles Include="$(WildlifeLookupMirrorSourceFile)" Condition="Exists('$(WildlifeLookupMirrorSourceFile)')" />
    </ItemGroup>
    <Copy
      SourceFiles="@(WildlifeLookupFiles)"
      DestinationFolder="$(OutputPath)"
      SkipUnchangedFiles="true"
      Condition="'@(WildlifeLookupFiles)' != ''" />
  </Target>
</Project>
